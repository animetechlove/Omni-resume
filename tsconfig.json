{
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "target": "esnext",
    "module": "commonjs",
    "lib": [
      "esnext"
    ],
    "jsx": "react-native",
    "noEmit": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "baseUrl": "."
  },
  "include": [
    "src",
    "App.tsx",
    "index.js"
  ],
  "extends": "expo/tsconfig.base"
}

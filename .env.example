# Copy this file to .env and fill in your values.
# .env is in .gitignore — it will never be pushed to GitHub.

# Get this from anilist.co/settings/developer → Create New Client
# Set redirect URI to: omniresume://oauth/anilist
#
# Must be prefixed EXPO_PUBLIC_ — that's what tells Expo/Metro to inline
# this value into the app bundle. Un-prefixed vars are never available at
# runtime in an Expo app, no matter what's in this file.
EXPO_PUBLIC_ANILIST_CLIENT_ID=your_anilist_client_id_here

{
  "name": "OmniResume",
  "displayName": "Omni-Resume",
  "expo": {
    "name": "Omni-Resume",
    "slug": "omni-resume",
    "owner": "inkstone-collective",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#0B0E1A",
    "android": {
      "package": "com.omniresume.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0E1A"
      },
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.omniresume.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan your platform QR tags to quickly log where you watched.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "extra": {
      "eas": {
        "projectId": "e6b59b25-52b7-4be8-8443-c43500839b83"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-font"
    ]
  }
}
